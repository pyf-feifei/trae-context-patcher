{
  "name": "trae-context-patcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/electron/main.js",
  "bin": {
    "trae-context-patcher": "./src/cli.js"
  },
  "scripts": {
    "dev": "electron .",
    "test": "node ./tests/run-tests.js",
    "status": "node ./src/cli.js status",
    "build:exe": "electron-builder --win portable"
  },
  "build": {
    "appId": "local.trae-context-patcher",
    "productName": "Trae Context Patcher",
    "artifactName": "${productName}-cn.exe",
    "directories": {
      "output": "dist"
    },
    "files": [
      "package.json",
      "README.md",
      "src/**/*"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1"
  }
}
